{
  "name": "zeus",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "prisma generate && prisma generate --schema=prisma/sqlserver/schema.prisma && next build",
    "start": "next start -p 3003",
    "lint": "next lint",
    "postinstall": "prisma generate && prisma generate --schema=prisma/sqlserver/schema.prisma",
    "setup": "prisma db push && npx ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/setup.ts",
    "db:generate": "prisma generate && prisma generate --schema=prisma/sqlserver/schema.prisma",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@react-pdf/renderer": "^4.3.2",
    "@twilio/voice-sdk": "^2.18.0",
    "autoprefixer": "^10.4.23",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.390.0",
    "mssql": "^12.2.0",
    "next": "14.2.5",
    "next-auth": "^4.24.13",
    "nodemailer": "^6.9.13",
    "pptxgenjs": "^4.0.1",
    "react": "^18",
    "react-dom": "^18",
    "sip.js": "^0.21.2",
    "tailwind-merge": "^2.3.0",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mssql": "^9.1.9",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
