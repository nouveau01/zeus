# Database - PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/nouveau_elevator?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# SMTP Email Configuration
SMTP_HOST="smtp.your-email-provider.com"
SMTP_PORT="587"
SMTP_USER="your-email@company.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="noreply@nouveauelevator.com"

# n8n Webhook Configuration (optional - for external integrations)
N8N_WEBHOOK_URL="http://your-n8n-instance:5678/webhook"
N8N_API_KEY="your-n8n-api-key"

# SQL Server Connection (for n8n to sync - reference only)
# MSSQL_HOST="your-sql-server.database.windows.net"
# MSSQL_DATABASE="your-database"
# MSSQL_USER="your-username"
# MSSQL_PASSWORD="your-password"
