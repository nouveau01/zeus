// Prisma Schema for ZEUS Field Service Management
//
// SQL Server 2008 Legacy Mapping Reference:
// ==========================================
// Customer  → Owner table (ID, settings) + Rol table (Name, Address, Contact via Owner.Rol → Rol.ID)
// Premises  → Loc table (Loc, settings) + Rol table (Name, Address, Contact via Loc.Rol → Rol.ID)
// Unit      → Elev table
// Job       → Job table
// Ticket    → TicketO table (Open tickets)
// Contract  → Contract table
// Contact   → Rol table (Type determines usage)
//
// Note: Currently using PostgreSQL. @map decorators show SQL Server column names.
// When migrating to SQL Server, uncomment the sqlserver provider and update types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // SQL Server 2008 (uncomment when ready):
  // provider = "sqlserver"
  // url      = env("SQLSERVER_URL")
}

// ============================================
// USERS
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?                        // Hashed password for authentication
  name      String
  role      String   @default("User")      // "GodAdmin", "Admin", or "User"
  avatar    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  createdJobs    Job[]        @relation("CreatedByUser")
  jobHistory     JobHistory[]
  activities     Activity[]
  files          File[]
  savedFilters   SavedFilter[]

  @@map("users")
}

// ============================================
// ROLES & PERMISSIONS
// ============================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique                    // e.g. "Technician", "Dispatcher", "Accountant"
  description String?
  isSystem    Boolean  @default(false) @map("is_system") // true for GodAdmin, Admin, User — can't delete
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  id        String   @id @default(cuid())
  roleId    String   @map("role_id")
  pageId    String   @map("page_id")              // Module name (e.g. "customers", "invoices")
  canAccess Boolean  @default(true) @map("can_access") // Can access this module at all
  fields    Json     @default("{}")                // { "fieldName": true/false } — field-level visibility
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, pageId])
  @@map("role_permissions")
}

// ============================================
// SAVED FILTERS
// ============================================

model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  pageId    String   @map("page_id")        // Which module this filter belongs to (e.g. "customers", "accounts")
  filters   Json                              // The filter/sort configuration
  isPublic  Boolean  @default(false) @map("is_public")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([pageId])
  @@index([userId])
  @@map("saved_filters")
}

// ============================================
// CUSTOMERS (SQL Server: Owner + Rol tables)
// ============================================
// Legacy: Owner.ID is PK, Owner.Rol → Rol.ID for name/address/contact
// OwnerWithRol view joins these tables

model Customer {
  id            String   @id @default(cuid())
  // SQL Server: Owner.ID (int) - will need Int type when migrating

  // From Rol table (via Owner.Rol → Rol.ID)
  name          String                              // Rol.Name
  address       String?                             // Rol.Address
  city          String?                             // Rol.City
  state         String?                             // Rol.State
  zipCode       String?  @map("zip_code")           // Rol.Zip
  country       String?  @default("United States")  // Rol.Country
  contact       String?                             // Rol.Contact
  phone         String?                             // Rol.Phone
  fax           String?                             // Rol.Fax
  cellular      String?                             // Rol.Cellular
  email         String?                             // Rol.EMail
  website       String?                             // Rol.Website
  remarks       String?                             // Rol.Remarks
  salesRemarks  String?  @map("sales_remarks")      // Rol.SalesRemarks
  position      String?                             // Rol.Position
  category      String?                             // Rol.Category

  // From Owner table directly
  status        Int?     @default(1)                // Owner.Status (smallint)
  locs          Int?     @default(0)                // Owner.Locs - count of locations
  elevs         Int?     @default(0)                // Owner.Elevs - count of elevators
  balance       Decimal  @default(0) @db.Decimal(12, 2)  // Owner.Balance
  type          String   @default("General")        // Owner.Type (varchar 15)
  billing       Int?     @default(0)                // Owner.Billing (smallint)
  internet      Int?     @default(0)                // Owner.Internet - portal access
  password      String?                             // Owner.Password
  custom1       String?                             // Owner.Custom1
  custom2       String?                             // Owner.Custom2
  ticketEmail   String?  @map("ticket_email")       // Owner.TicketEmail
  quoteEmail    String?  @map("quote_email")        // Owner.QuoteEmail

  // Internal reference to Rol record
  rolId         Int?     @map("rol_id")             // Owner.Rol → Rol.ID

  // Legacy flags (smallint in Owner table)
  ticketO       Int?     @default(0) @map("ticket_o")     // Owner.TicketO
  ticketD       Int?     @default(0) @map("ticket_d")     // Owner.TicketD
  ledger        Int?     @default(0)                      // Owner.Ledger
  statement     Int?     @default(0)                      // Owner.Statement
  approve       Int?     @default(0)                      // Owner.Approve
  invoiceO      Int?     @default(0) @map("invoice_o")    // Owner.InvoiceO
  quote         Int?     @default(0)                      // Owner.Quote
  quoteX        Int?     @default(0) @map("quote_x")      // Owner.QuoteX
  dispatch      Int?     @default(0)                      // Owner.Dispatch
  service       Int?     @default(0)                      // Owner.Service
  pay           Int?     @default(0)                      // Owner.Pay
  safety        Int?     @default(0)                      // Owner.Safety

  // Computed/display fields (not in legacy, for our app)
  accountNumber String?  @unique @map("account_number")
  isActive      Boolean  @default(true) @map("is_active")
  portalAccess  Boolean  @default(false) @map("portal_access")
  currentYearSales  Decimal  @default(0) @db.Decimal(12, 2) @map("current_year_sales")
  priorYearSales    Decimal  @default(0) @db.Decimal(12, 2) @map("prior_year_sales")

  // Timestamps (not in legacy - our app tracking)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  premises      Premises[]
  jobs          Job[]
  contacts      Contact[]
  contracts     Contract[]
  tickets       Ticket[]   @relation("CustomerTickets")

  @@map("customers")
  // SQL Server: @@map("Owner") - but need to handle Rol join
}

// ============================================
// CONTACTS (Customer Contacts)
// ============================================

model Contact {
  id          String   @id @default(cuid())
  name        String
  title       String?
  phone       String?
  fax         String?
  mobile      String?
  email       String?
  inv         Boolean  @default(false)
  es          Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

// ============================================
// PREMISES (SQL Server: Loc + Rol tables)
// ============================================
// Legacy: Loc.Loc is PK (int), Loc.Rol → Rol.ID for contact info
// Loc.Owner → Owner.ID links to Customer

model Premises {
  id          String   @id @default(cuid())
  // SQL Server: Loc.Loc (int) - will need Int type when migrating

  // From Loc table directly
  locId       String?  @unique @map("loc_id")       // Loc.ID (varchar 15) - display ID like "195BROAD"
  tag         String?                               // Loc.Tag (varchar 50)
  address     String                                // Loc.Address
  city        String?                               // Loc.City
  state       String?                               // Loc.State
  zipCode     String?  @map("zip_code")             // Loc.Zip
  country     String?  @default("United States")    // Loc.Country
  elevs       Int?     @default(0)                  // Loc.Elevs - count of elevators
  status      Int?     @default(1)                  // Loc.Status (smallint)
  balance     Decimal  @default(0) @db.Decimal(12, 2)  // Loc.Balance
  type        String?  @default("Non-Contract")     // Loc.Type (varchar 15)
  billing     Int?     @default(0)                  // Loc.Billing (smallint)
  route       Int?     @default(0)                  // Loc.Route
  zone        Int?     @default(0)                  // Loc.Zone
  terr        Int?     @default(0)                  // Loc.Terr (territory)
  priceL      Int?     @default(0) @map("price_l")  // Loc.PriceL (price level)
  maint       Int?     @default(0)                  // Loc.Maint
  inUse       Int?     @default(0) @map("in_use")   // Loc.InUse
  wk          Int?                                  // Loc.WK
  terms       Int?                                  // Loc.Terms
  credit      Int?                                  // Loc.Credit
  creditReason String? @map("credit_reason")        // Loc.CreditReason

  // Tax settings
  sTax        String?  @map("s_tax")                // Loc.STax
  sTax2       String?  @map("s_tax_2")              // Loc.STax2
  uTax        String?  @map("u_tax")                // Loc.UTax

  // Markup rates
  markup1     Float?                                // Loc.Markup1
  markup2     Float?                                // Loc.Markup2
  markup3     Float?                                // Loc.Markup3
  markup4     Float?                                // Loc.Markup4
  markup5     Float?                                // Loc.Markup5

  // Location
  longitude   Float?   @map("longitude")            // Loc.fLong
  latitude    Float?   @map("latitude")             // Loc.Latt
  geoLock     Int?     @default(0) @map("geo_lock") // Loc.GeoLock

  // From Rol table (via Loc.Rol → Rol.ID)
  name        String?                               // Rol.Name
  contact     String?                               // Rol.Contact
  phone       String?                               // Rol.Phone
  fax         String?                               // Rol.Fax
  cellular    String?                               // Rol.Cellular
  email       String?                               // Rol.EMail (mapped from Loc.Email flag + Rol)
  website     String?                               // Rol.Website
  careof      String?                               // Loc.Careof

  // Remarks
  remarks     String?                               // Loc.Remarks
  colRemarks  String?  @map("col_remarks")          // Loc.ColRemarks
  salesRemarks String? @map("sales_remarks")        // Loc.SalesRemarks

  // Custom fields
  custom1     String?                               // Loc.Custom1
  custom2     String?                               // Loc.Custom2
  custom3     String?                               // Loc.Custom3
  custom4     String?                               // Loc.Custom4
  custom5     String?                               // Loc.Custom5
  custom6     String?                               // Loc.Custom6
  custom7     String?                               // Loc.Custom7
  custom8     String?                               // Loc.Custom8
  custom9     String?                               // Loc.Custom9
  custom10    String?                               // Loc.Custom10
  custom11    String?                               // Loc.Custom11
  custom12    String?                               // Loc.Custom12
  custom13    String?                               // Loc.Custom13
  custom14    String?                               // Loc.Custom14
  custom15    String?                               // Loc.Custom15

  // Payment statistics
  paidNumb    Int?     @map("paid_numb")            // Loc.PaidNumb - number of payments
  paidDays    Int?     @map("paid_days")            // Loc.PaidDays - days to pay
  writeOff    Decimal? @db.Decimal(12, 2) @map("write_off") // Loc.WriteOff

  // Payment processing
  merchantServicesId    Int? @map("merchant_services_id")     // Loc.MerchantServicesId
  idCreditCardDefault   Int? @map("id_credit_card_default")   // Loc.idCreditCardDefault

  // Flags
  dispAlert     Int?     @default(0) @map("disp_alert")       // Loc.DispAlert (tinyint)
  dispAlertType String?  @map("disp_alert_type")              // Loc.DispAlertType (varchar 15)
  emailFlag     Int?     @default(0) @map("email_flag")       // Loc.Email (tinyint) - flag for email preference
  emailTicket   Boolean  @default(false) @map("email_ticket") // Loc.EmailTicket (bit)
  printTicket   Boolean  @default(false) @map("print_ticket") // Loc.PrintTicket (bit)
  printInvoice  Boolean  @default(false) @map("print_invoice")// Loc.PrintInvoice (bit)
  require       Int?     @map("require")                      // Loc.Require

  // TFM Integration
  tfmId         String?  @map("tfm_id")             // Loc.TFMID (varchar 100)
  tfmSource     String?  @map("tfm_source")         // Loc.TFMSource (varchar 10)

  // Internal references to Rol records
  rolId              Int?  @map("rol_id")                  // Loc.Rol → Rol.ID (main contact)
  idRolCustomContact Int?  @map("id_rol_custom_contact")   // Loc.idRolCustomContact → Rol.ID

  // Reference to current/default job
  currentJobId  Int?     @map("current_job_id")     // Loc.Job → Job.ID

  // Computed/display fields (not in legacy, for our app)
  premisesId  String?  @unique @map("premises_id")
  isActive    Boolean  @default(true) @map("is_active")

  // Timestamps (not in legacy - our app tracking)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customerId  String?  @map("customer_id")          // Loc.Owner → Owner.ID
  customer    Customer? @relation(fields: [customerId], references: [id])
  jobs        Job[]
  units       Unit[]
  invoices    Invoice[]
  tickets     Ticket[]
  contracts   Contract[]
  quotes      Quote[]

  @@map("premises")
  // SQL Server: @@map("Loc")
}

// ============================================
// EMPLOYEE (SQL Server: Emp table)
// 122 columns in Total Service - this is a simplified version
// ============================================

model Employee {
  id            Int       @id @default(autoincrement())
  // SQL Server: Emp.ID (int, identity)

  // Basic Info
  fFirst        String?   @map("f_first")                 // Emp.FFirst - first name
  last          String?                                   // Emp.Last - last name
  name          String                                    // Emp.Name - full name (LAST, FIRST format)
  rol           Int?                                      // Emp.Rol - FK to Rol table
  title         String?                                   // Emp.Title - job title (FOREMAN MAINT, A MECHANIC MAINT, OFFICE, etc.)

  // Flags
  sales         Int       @default(0)                     // Emp.Sales - sales employee flag
  field         Int       @default(0)                     // Emp.Field - field employee flag
  status        Int       @default(1)                     // Emp.Status - active status (0=inactive, 1=active)
  inUse         Int       @default(0) @map("in_use")      // Emp.InUse

  // Contact
  pager         String?                                   // Emp.Pager - email address

  // Dates
  dHired        DateTime? @map("d_hired")                 // Emp.DHired - hire date
  dFired        DateTime? @map("d_fired")                 // Emp.DFired - termination date
  dBirth        DateTime? @map("d_birth")                 // Emp.DBirth - birth date
  dReview       DateTime? @map("d_review")                // Emp.DReview - review date
  dLast         DateTime? @map("d_last")                  // Emp.DLast - last activity date

  // Location/Status
  state         String?                                   // Emp.State - NY, NJ, etc.
  level         Int?                                      // Emp.Level - employee level
  catSign       String?   @map("cat_sign")                // Emp.CatSign - signature/display name

  // Flags for status
  fStatus       Int?      @default(0) @map("f_status")    // Emp.FStatus
  fAllow        Int?      @default(1) @map("f_allow")     // Emp.FAllow

  // Payroll (simplified - many more fields in actual table)
  payPeriod     Int?      @default(0) @map("pay_period")  // Emp.PayPeriod
  salary        Decimal?  @db.Decimal(12, 2)              // Emp.Salary
  prTaxI        Int?      @default(100) @map("pr_tax_i")  // Emp.PRTaxI

  // Reference
  ref           Int?                                      // Emp.Ref - reference number

  // TFM Integration
  tfmId         Int?      @map("tfm_id")                  // Emp.TFMID
  tfmSource     String?   @map("tfm_source")              // Emp.TFMSource

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("employees")
  // SQL Server: @@map("Emp")
}

// ============================================
// ROUTES (SQL Server: Route table)
// Maintenance routes with assigned mechanics
// ============================================

model Route {
  id            Int       @id @default(autoincrement())
  // SQL Server: Route.ID (int, identity)

  name          String                                    // Route.Name - route identifier (00, 202, 309 - LOC 4, etc.)
  mech          Int?                                      // Route.Mech - FK to mechanic/employee (Rol table)
  loc           Int       @default(0)                     // Route.Loc - location/account count (may be calculated)
  elev          Int       @default(0)                     // Route.Elev - elevator/unit count (may be calculated)
  hour          Decimal   @default(0) @db.Decimal(12, 2)  // Route.Hour - hours
  amount        Decimal   @default(0) @db.Decimal(12, 2)  // Route.Amount - revenue amount
  remarks       String?   @db.Text                        // Route.Remarks - notes/change history
  symbol        Int?                                      // Route.Symbol
  en            Int?      @default(1)                     // Route.EN - enabled flag?
  tfmId         Int?      @map("tfm_id")                  // Route.TFMID
  tfmSource     String?   @map("tfm_source")              // Route.TFMSource

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("routes")
  // SQL Server: @@map("Route")
}

// ============================================
// UNITS (SQL Server: Elev table)
// ============================================
// Legacy: Elev.ID is PK (int)
// Elev.Loc → Loc.Loc, Elev.Owner → Owner.ID

model Unit {
  id           String   @id @default(cuid())
  // SQL Server: Elev.ID (int) - will need Int type when migrating

  // From Elev table
  unitNumber   String   @map("unit_number")         // Elev.Unit (varchar 255) - display name
  state        String?                              // Elev.State (varchar 25) - state number
  cat          String?  @map("category")            // Elev.Cat (varchar 20) - category
  unitType     String?  @map("unit_type")           // Elev.Type (varchar 20)
  building     String?                              // Elev.Building (varchar 20)
  manufacturer String?                              // Elev.Manuf (varchar 50)
  serial       String?                              // Elev.Serial (varchar 50)
  description  String?                              // Elev.fDesc (varchar 255)
  remarks      String?                              // Elev.Remarks (text)
  status       String?  @default("Active")           // Elev.Status (smallint in SQL Server: 1=Active)
  price        Decimal? @db.Decimal(12, 2)          // Elev.Price
  group        String?                              // Elev.fGroup (varchar 25)
  week         String?                              // Elev.Week (varchar 50)
  template     String?                              // Elev.Template (smallint in SQL Server)

  // Dates
  installDate  DateTime? @map("install_date")       // Elev.Install
  installBy    String?   @map("install_by")         // Elev.InstallBy (varchar 25)
  sinceDate    DateTime? @map("since_date")         // Elev.Since
  lastDate     DateTime? @map("last_date")          // Elev.Last

  // Custom fields (Elev.Custom1 through Custom20)
  custom1      String?
  custom2      String?
  custom3      String?
  custom4      String?
  custom5      String?
  custom6      String?
  custom7      String?
  custom8      String?
  custom9      String?
  custom10     String?
  custom11     String?
  custom12     String?
  custom13     String?
  custom14     String?
  custom15     String?
  custom16     String?
  custom17     String?
  custom18     String?
  custom19     String?
  custom20     String?

  // Computed/display fields
  isActive     Boolean  @default(true) @map("is_active")

  // Timestamps (not in legacy - our app tracking)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  premisesId   String   @map("premises_id")         // Elev.Loc → Loc.Loc
  premises     Premises @relation(fields: [premisesId], references: [id])
  jobs         Job[]
  tickets      Ticket[]

  @@map("units")
  // SQL Server: @@map("Elev")
}

// ============================================
// JOBS (SQL Server: Job table)
// ============================================
// Legacy: Job.ID is PK (int)
// Job.Loc → Loc.Loc, Job.Owner → Owner.ID, Job.Elev → Elev.ID

model Job {
  id              String    @id @default(cuid())
  // SQL Server: Job.ID (int) - will need Int type when migrating

  // From Job table
  jobName         String    @map("job_name")        // Job.fDesc (varchar 255)
  externalId      String?   @unique @map("external_id")
  jobDescription  String?   @map("job_description") // Job.Remarks (varchar max)
  status          String?   @default("Open")        // Job.Status (smallint in SQL Server)
  type            String?                           // Job.Type (smallint in SQL Server)
  po              String?                           // Job.PO (varchar 25)
  group           String?                           // Job.fGroup (varchar 25)
  cType           String?   @map("c_type")          // Job.CType (varchar 15)
  fp              String?                           // Job.FP (varchar 15)
  skill           String?                           // From Contract.Skill

  // Dates
  date            DateTime? @map("date")            // Job.fDate
  closeDate       DateTime? @map("close_date")      // Job.CloseDate
  estDate         DateTime? @map("est_date")        // Job.EstDate
  dueDate         DateTime? @map("due_date")        // Job.DueDate

  // Financial - Revenue
  rev             Decimal   @default(0) @db.Decimal(12, 2)  // Job.Rev
  bRev            Decimal   @default(0) @db.Decimal(12, 2) @map("b_rev")  // Job.BRev (budget)

  // Financial - Costs
  mat             Decimal   @default(0) @db.Decimal(12, 2)  // Job.Mat (materials)
  labor           Decimal   @default(0) @db.Decimal(12, 2)  // Job.Labor
  cost            Decimal   @default(0) @db.Decimal(12, 2)  // Job.Cost
  profit          Decimal   @default(0) @db.Decimal(12, 2)  // Job.Profit
  ratio           Decimal   @default(0) @db.Decimal(10, 2)  // Job.Ratio
  bMat            Decimal   @default(0) @db.Decimal(12, 2) @map("b_mat")  // Job.BMat
  bLabor          Decimal   @default(0) @db.Decimal(12, 2) @map("b_labor") // Job.BLabor
  bCost           Decimal   @default(0) @db.Decimal(12, 2) @map("b_cost")  // Job.BCost
  bProfit         Decimal   @default(0) @db.Decimal(12, 2) @map("b_profit") // Job.BProfit
  bRatio          Decimal   @default(0) @db.Decimal(10, 2) @map("b_ratio")  // Job.BRatio

  // Hours
  reg             Decimal   @default(0) @db.Decimal(10, 2)  // Job.Reg
  ot              Decimal   @default(0) @db.Decimal(10, 2)  // Job.OT
  dt              Decimal   @default(0) @db.Decimal(10, 2)  // Job.DT
  tt              Decimal   @default(0) @db.Decimal(10, 2)  // Job.TT
  nt              Decimal   @default(0) @db.Decimal(10, 2)  // Job.NT
  hour            Decimal   @default(0) @db.Decimal(10, 2)  // Job.Hour
  bHour           Decimal   @default(0) @db.Decimal(10, 2) @map("b_hour")  // Job.BHour
  comm            Decimal   @default(0) @db.Decimal(10, 2)  // Job.Comm

  // Rates
  billRate        Decimal   @default(0) @db.Decimal(10, 2) @map("bill_rate")  // Job.BillRate
  markup          Decimal   @default(0) @db.Decimal(10, 2)  // Job.Markup
  rateTravel      Decimal?  @db.Decimal(10, 2) @map("rate_travel")  // Job.RateTravel
  rateOT          Decimal?  @db.Decimal(10, 2) @map("rate_ot")      // Job.RateOT
  rateNT          Decimal?  @db.Decimal(10, 2) @map("rate_nt")      // Job.RateNT
  rateDT          Decimal?  @db.Decimal(10, 2) @map("rate_dt")      // Job.RateDT
  rateMileage     Decimal?  @db.Decimal(10, 2) @map("rate_mileage") // Job.RateMileage

  // Overhead
  gAndA           Decimal   @default(0) @db.Decimal(10, 2) @map("g_and_a")  // Job.GandA
  ohLabor         Decimal   @default(0) @db.Decimal(10, 2) @map("oh_labor") // Job.OHLabor
  lastOH          Decimal   @default(0) @db.Decimal(10, 2) @map("last_oh")  // Job.LastOH
  etc             Decimal   @default(0) @db.Decimal(10, 2)  // Job.etc
  etcModifier     Decimal   @default(0) @db.Decimal(10, 2) @map("etc_modifier") // Job.ETCModifier

  // Settings
  template        String?                           // Job.Template (smallint in SQL Server)
  wageC           Int?      @map("wage_c")          // Job.WageC (wage code)
  post            Int?      @default(0)             // Job.Post
  en              Int?      @default(0)             // Job.EN
  certified       Int?      @default(0)             // Job.Certified
  apprentice      Int?      @default(0)             // Job.Apprentice
  useCat          Int?      @default(0) @map("use_cat")   // Job.UseCat
  useDed          Int?      @default(0) @map("use_ded")   // Job.UseDed
  pType           Int?      @default(0) @map("p_type")    // Job.PType
  charge          Int?      @default(0)             // Job.Charge
  amount          Decimal   @default(0) @db.Decimal(12, 2) // Job.Amount
  gl              Int?                              // Job.GL
  glRev           Int?      @map("gl_rev")          // Job.GLRev
  elevs           Int?                              // Job.Elevs
  level           Int?                              // Job.Level

  // Remarks
  sRemarks        String?   @map("s_remarks")       // Job.SRemarks
  comments        String?                           // Job.Comments

  // Audit
  source          String?                           // Job.Source
  reopen          Int?      @default(0)             // Job.Reopen
  audit           Int?      @default(0)             // Job.Audit
  auditBy         String?   @map("audit_by")        // Job.AuditBy
  auditDate       DateTime? @map("audit_date")      // Job.AuditDate
  ncsLock         Int?      @default(0) @map("ncs_lock")   // Job.NCSLock
  ncsClose        DateTime? @map("ncs_close")       // Job.NCSClose
  fInt            Int?      @default(0) @map("f_int")      // Job.fInt

  // Tech assignment
  tech            String?                           // Job.Tech
  techOrRoute     Int?      @map("tech_or_route")   // Job.TechOrRoute
  techAlert       String?   @map("tech_alert")      // Job.TechAlert

  // Custom fields (Job.Custom1 through Custom20)
  custom1         String?
  custom2         String?
  custom3         String?
  custom4         String?
  custom5         String?
  custom6         String?
  custom7         String?
  custom8         String?
  custom9         String?
  custom10        String?
  custom11        String?
  custom12        String?
  custom13        String?
  custom14        String?
  custom15        String?
  custom16        String?
  custom17        String?
  custom18        String?
  custom19        String?
  custom20        String?

  // Timestamps (not in legacy - our app tracking)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  customerId      String?   @map("customer_id")     // Job.Owner → Owner.ID
  customer        Customer? @relation(fields: [customerId], references: [id])

  premisesId      String?   @map("premises_id")     // Job.Loc → Loc.Loc
  premises        Premises? @relation(fields: [premisesId], references: [id])

  unitId          String?   @map("unit_id")         // Job.Elev → Elev.ID
  unit            Unit?     @relation(fields: [unitId], references: [id])

  createdById     String?   @map("created_by_id")
  createdBy       User?     @relation("CreatedByUser", fields: [createdById], references: [id])

  // Related records
  history         JobHistory[]
  activities      Activity[]
  files           File[]
  notes           Note[]
  tickets         Ticket[]
  invoices        Invoice[]
  invoiceItems    InvoiceItem[]
  contracts       Contract[]
  quotes          Quote[]

  @@map("jobs")
  // SQL Server: @@map("Job")
}

// ============================================
// JOB TYPES (SQL Server: JobType table)
// ============================================
// Categorizes jobs (Annual, Repair, Maintenance, etc.)

model JobType {
  id            String   @id @default(cuid())
  legacyId      Int?     @unique @map("legacy_id")

  name          String   @unique                          // Type name
  description   String?                                   // Optional description
  count         Int      @default(0)                      // Count of jobs using this type
  color         String?                                   // Color for UI display
  remarks       String?                                   // Additional notes
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  templates     JobTemplate[]

  @@map("job_types")
}

// ============================================
// JOB TEMPLATES (SQL Server: JobTemplate table)
// ============================================
// Pre-configured job settings that can be applied when creating jobs

model JobTemplate {
  id            String   @id @default(cuid())
  legacyId      Int?     @unique @map("legacy_id")

  name          String                                    // Template name/description
  typeId        String?  @map("type_id")                  // FK to JobType
  revNum        Int      @default(1) @map("rev_num")      // # Rev (revenue accounts)
  expNum        Int      @default(2) @map("exp_num")      // # Exp (expense accounts)
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")

  // Default job settings when using this template
  defaultStatus     String?  @map("default_status")
  defaultContractType String? @map("default_contract_type")
  defaultBillRate   Decimal? @db.Decimal(10, 2) @map("default_bill_rate")
  defaultMarkup     Decimal? @db.Decimal(10, 2) @map("default_markup")
  isBillable        Boolean  @default(true) @map("is_billable")
  isChargeable      Boolean  @default(true) @map("is_chargeable")

  // GL Account defaults
  glRevenue     Int?     @map("gl_revenue")
  glExpense     Int?     @map("gl_expense")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  type          JobType? @relation(fields: [typeId], references: [id])

  @@map("job_templates")
}

// ============================================
// CONTRACTS (SQL Server: Contract table)
// ============================================
// Legacy: Contract.ID is PK (int)
// Contract.Loc → Loc.Loc, Contract.Owner → Owner.ID, Contract.Job → Job.ID

model Contract {
  id            String    @id @default(cuid())
  // SQL Server: Contract.ID (int) - will need Int type when migrating

  // Dates
  review        DateTime?                           // Contract.Review
  bStart        DateTime? @map("b_start")           // Contract.BStart (billing start)
  bFinish       DateTime? @map("b_finish")          // Contract.BFinish (billing finish)
  sStart        DateTime? @map("s_start")           // Contract.SStart (service start)
  sTime         DateTime? @map("s_time")            // Contract.STime
  sTime2        DateTime? @map("s_time_2")          // Contract.sTime2
  escLast       DateTime? @map("esc_last")          // Contract.EscLast (last escalation)
  offService    DateTime? @map("off_service")       // Contract.OffService

  // Discounts
  disc1         Decimal   @default(0) @db.Decimal(12, 2)  // Contract.Disc1
  disc2         Decimal   @default(0) @db.Decimal(12, 2)  // Contract.Disc2
  disc3         Decimal   @default(0) @db.Decimal(12, 2)  // Contract.Disc3
  disc4         Decimal   @default(0) @db.Decimal(12, 2)  // Contract.Disc4
  disc5         Decimal   @default(0) @db.Decimal(12, 2)  // Contract.Disc5
  disc6         Decimal   @default(0) @db.Decimal(12, 2)  // Contract.Disc6
  discType      Int?      @map("disc_type")               // Contract.DiscType (smallint)
  discRate      Decimal   @default(0) @db.Decimal(12, 2) @map("disc_rate")  // Contract.DiscRate

  // Billing
  bCycle        Int?      @map("b_cycle")           // Contract.BCycle (billing cycle)
  bLength       Int?      @map("b_length")          // Contract.BLenght (typo in legacy)
  bAmt          Decimal   @default(0) @db.Decimal(12, 2) @map("b_amt")  // Contract.BAmt (billing amount)
  bEscType      Int?      @map("b_esc_type")        // Contract.BEscType
  bEscCycle     Int?      @map("b_esc_cycle")       // Contract.BEscCycle
  bEscFact      Decimal   @default(0) @db.Decimal(12, 2) @map("b_esc_fact")  // Contract.BEscFact

  // Service scheduling
  sCycle        Int?      @map("s_cycle")           // Contract.SCycle
  sType         String?   @map("s_type")            // Contract.SType (varchar 10)
  sDay          Int?      @map("s_day")             // Contract.SDay
  sDate         Int?      @map("s_date")            // Contract.SDate
  sWE           Int       @default(0) @map("s_we")  // Contract.SWE
  sDay2         Int?      @map("s_day_2")           // Contract.sDay2
  sDate2        Int?      @map("s_date_2")          // Contract.sDate2
  sWE2          Int?      @map("s_we_2")            // Contract.sWE2

  // Other settings
  detail        Int?                                // Contract.Detail
  cycle         Int?                                // Contract.Cycle
  oldAmt        Decimal   @default(0) @db.Decimal(12, 2) @map("old_amt")  // Contract.OldAmt
  wk            Int?                                // Contract.WK
  skill         String?                             // Contract.Skill (varchar 25)
  status        Int?      @default(1)               // Contract.Status (smallint)
  hours         Decimal   @default(0) @db.Decimal(10, 2)  // Contract.Hours
  hour          Decimal   @default(0) @db.Decimal(10, 2)  // Contract.Hour
  terms         Int?                                // Contract.Terms

  // Timestamps (not in legacy - our app tracking)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  customerId    String?   @map("customer_id")       // Contract.Owner → Owner.ID
  customer      Customer? @relation(fields: [customerId], references: [id])

  premisesId    String?   @map("premises_id")       // Contract.Loc → Loc.Loc
  premises      Premises? @relation(fields: [premisesId], references: [id])

  jobId         String?   @map("job_id")            // Contract.Job → Job.ID
  job           Job?      @relation(fields: [jobId], references: [id])

  @@map("contracts")
  // SQL Server: @@map("Contract")
}

// ============================================
// JOB HISTORY (Audit Trail)
// ============================================

model JobHistory {
  id            String   @id @default(cuid())
  field         String
  originalValue String?  @map("original_value")
  newValue      String?  @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  jobId         String   @map("job_id")
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  userId        String?  @map("user_id")
  user          User?    @relation(fields: [userId], references: [id])

  @@map("job_history")
}

// ============================================
// ACTIVITY FEED
// ============================================

model Activity {
  id          String   @id @default(cuid())
  type        String
  content     String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  jobId       String?  @map("job_id")
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  @@map("activities")
}

// ============================================
// FILES
// ============================================

model File {
  id           String   @id @default(cuid())
  name         String
  url          String
  size         Int?
  mimeType     String?  @map("mime_type")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  jobId        String?  @map("job_id")
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  uploadedById String?  @map("uploaded_by_id")
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@map("files")
}

// ============================================
// NOTES
// ============================================

model Note {
  id          String   @id @default(cuid())
  title       String?
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  jobId       String?  @map("job_id")
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// ============================================
// TICKETS (SQL Server: TicketO table)
// ============================================
// Legacy: TicketO.ID is PK (int)
// TicketO.LID → Loc.Loc, TicketO.Owner → Owner.ID, TicketO.Job → Job.ID, TicketO.LElev → Elev.ID
//
// SQL Server Field Mappings (for migration reference):
// ticketNumber → TicketO.ID, date → TicketO.CDate, type → TicketO.Type
// category → TicketO.Cat, status → computed, accountId → TicketO.LDesc1
// mechCrew → TicketO.DWork, hours → TicketO.Reg, unitName → from Elev relation

model Ticket {
  id              String   @id @default(cuid())
  ticketNumber    Int      @unique @map("ticket_number")  // TicketO.ID
  workOrderNumber Int?     @map("work_order_number")      // TicketO.WorkOrder

  // Date/Time
  date            DateTime                          // TicketO.CDate
  completedDate   DateTime? @map("completed_date")  // TicketO.EDate

  // Classification
  type            String   @default("Other")        // TicketO.Type (map: Maintenance=1, etc.)
  category        String?                           // TicketO.Cat
  level           String?                           // TicketO.Level
  status          String   @default("Open")         // Computed from TicketO fields

  // Location identifier
  accountId       String?  @map("account_id")       // TicketO.LDesc1

  // Personnel
  mechCrew        String?  @map("mech_crew")        // TicketO.DWork
  supervisor      String?                           // From Job relation
  wage            String?

  // Job & Unit
  phase           Int?     @default(1)
  unitName        String?  @map("unit_name")        // From Elev.Unit via relation

  // Name & Address display
  nameAddress     String?  @map("name_address")     // TicketO.LDesc3

  // Scope of Work
  scopeOfWork     String?  @map("scope_of_work")    // TicketO.fDesc

  // Resolution
  resolution      String?                           // TicketO.Resolution

  // Parts Used
  partsUsed       String?  @map("parts_used")       // TicketO.PartsUsed

  // Work Performed section
  workTime        String?  @map("work_time")

  // Time Frame
  enRouteTime     String?  @map("en_route_time")    // TicketO.TimeRoute
  onSiteTime      String?  @map("on_site_time")     // TicketO.TimeSite
  completedTime   String?  @map("completed_time")   // TicketO.TimeComp

  // Mileage
  mileageStarting Int?     @default(0) @map("mileage_starting")  // TicketO.SMile
  mileageEnding   Int?     @default(0) @map("mileage_ending")    // TicketO.EMile
  mileageTraveled Int?     @default(0) @map("mileage_traveled")

  // Time Spent (hours breakdown)
  hours           Decimal  @default(0) @db.Decimal(10, 2)  // TicketO.Reg
  overtimeHours   Decimal  @default(0) @db.Decimal(10, 2) @map("overtime_hours")  // TicketO.OT
  oneSevenHours   Decimal  @default(0) @db.Decimal(10, 2) @map("one_seven_hours")
  doubleTimeHours Decimal  @default(0) @db.Decimal(10, 2) @map("double_time_hours")  // TicketO.DT
  travelHours     Decimal  @default(0) @db.Decimal(10, 2) @map("travel_hours")  // TicketO.TT
  totalHours      Decimal  @default(0) @db.Decimal(10, 2) @map("total_hours")  // TicketO.Total
  estTime         Decimal  @default(0) @db.Decimal(10, 2) @map("est_time")  // TicketO.Est
  difference      Decimal  @default(0) @db.Decimal(10, 2)

  // Expenses
  expensePhase    Int?     @default(1) @map("expense_phase")
  expenseMileage  Decimal  @default(0) @db.Decimal(10, 2) @map("expense_mileage")  // TicketO.Mileage
  expenseZone     Decimal  @default(0) @db.Decimal(10, 2) @map("expense_zone")  // TicketO.Zone
  expenseTolls    Decimal  @default(0) @db.Decimal(10, 2) @map("expense_tolls")  // TicketO.Toll
  expenseMisc     Decimal  @default(0) @db.Decimal(10, 2) @map("expense_misc")  // TicketO.OtherE
  expenseTotal    Decimal  @default(0) @db.Decimal(10, 2) @map("expense_total")

  // Checkbox statuses
  bill            Boolean  @default(false)
  reviewed        Boolean  @default(false)
  pr              Boolean  @default(false)
  vd              Boolean  @default(false)
  inv             Boolean  @default(false)

  // Detail view checkboxes
  workCompleted   Boolean  @default(false) @map("work_completed")
  chargeable      Boolean  @default(false)
  emailOnSave     Boolean  @default(false) @map("email_on_save")
  updateLocation  Boolean  @default(false) @map("update_location")
  internetAccess  Boolean  @default(true) @map("internet_access")  // TicketO.Internet

  // Review Status
  reviewStatus    String?  @default("Dispatch Review") @map("review_status")

  // Contract Type
  contractType    String?  @map("contract_type")

  // Internal Comments
  internalComments String? @map("internal_comments")  // TicketO.Notes

  // Call tracking
  calledInBy      String?  @map("called_in_by")  // TicketO.fBy
  calledInDate    DateTime? @map("called_in_date")
  takenBy         String?  @map("taken_by")
  resolvedBy      String?  @map("resolved_by")

  // Email
  emailStatus     String?  @default("No Email Sent") @map("email_status")

  // Description/Notes
  description     String?

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  customerId      String?  @map("customer_id")  // TicketO.Owner
  customer        Customer? @relation("CustomerTickets", fields: [customerId], references: [id])

  premisesId      String?  @map("premises_id")  // TicketO.LID
  premises        Premises? @relation(fields: [premisesId], references: [id])

  unitId          String?  @map("unit_id")  // TicketO.LElev
  unit            Unit?    @relation(fields: [unitId], references: [id])

  jobId           String?  @map("job_id")  // TicketO.Job
  job             Job?     @relation(fields: [jobId], references: [id])

  invoiceId       String?  @map("invoice_id")
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  // Quotes generated from this ticket
  quotes          Quote[]

  @@map("tickets")
  // SQL Server: @@map("TicketO")
}

// ============================================
// INVOICES
// ============================================

model Invoice {
  id              String    @id @default(cuid())
  // SQL Server: Invoice.Ref (int, PK) - will need Int type when migrating

  // From Invoice table
  ref             Int?      @unique                         // Invoice.Ref (int) - invoice reference number
  invoiceNumber   Int       @unique @map("invoice_number")  // Display number (same as Ref for legacy)
  fDate           DateTime? @map("f_date")                  // Invoice.fDate - invoice date
  iDate           DateTime? @map("i_date")                  // Invoice.IDate - ? date
  fDesc           String?   @map("f_desc")                  // Invoice.fDesc (text) - description
  remarks         String?                                   // Invoice.Remarks (text)

  // Amounts
  amount          Decimal   @default(0) @db.Decimal(12, 2)  // Invoice.Amount - subtotal before tax
  sTax            Decimal   @default(0) @db.Decimal(12, 2) @map("s_tax")  // Invoice.STax - sales tax
  total           Decimal   @default(0) @db.Decimal(12, 2)  // Invoice.Total
  taxable         Decimal   @default(0) @db.Decimal(12, 2)  // Invoice.Taxable - taxable amount
  gTax            Decimal?  @db.Decimal(12, 2) @map("g_tax") // Invoice.GTax - GST/other tax
  pstOnlyAmount   Decimal?  @db.Decimal(12, 2) @map("pst_only_amount") // Invoice.PSTOnlyAmount

  // Tax Settings
  taxRegion       String?   @map("tax_region")              // Invoice.TaxRegion (varchar 25)
  taxRate         Decimal   @default(0) @db.Decimal(8, 4) @map("tax_rate") // Invoice.TaxRate
  taxFactor       Decimal   @default(100) @db.Decimal(8, 2) @map("tax_factor") // Invoice.TaxFactor
  taxRegion2      String?   @map("tax_region_2")            // Invoice.TaxRegion2
  taxRate2        Decimal   @default(0) @db.Decimal(8, 4) @map("tax_rate_2") // Invoice.TaxRate2

  // Classification
  type            String?   @default("Other")               // Invoice.Type (smallint in SQL Server)
  terms           String?   @default("Net 30 Days")         // Invoice.Terms (smallint in SQL Server)
  pricing         Int?      @default(0)                     // Invoice.Pricing (smallint)
  status          String?   @default("Open")                // Invoice.Status (smallint in SQL Server)

  // Reference Fields
  po              String?                                   // Invoice.PO (varchar 25)
  batch           Int?                                      // Invoice.Batch
  transId         Int?      @map("trans_id")                // Invoice.TransID
  mech            Int?                                      // Invoice.Mech - mechanic/tech ID

  // Bill To
  billToOpt       Int?      @map("bill_to_opt")             // Invoice.BillToOpt (tinyint)
  billTo          String?   @map("bill_to")                 // Invoice.BillTo (varchar 1000)

  // Custom Fields
  custom1         String?                                   // Invoice.Custom1 (varchar 50)
  custom2         String?                                   // Invoice.Custom2 (varchar 50)
  custom3         String?                                   // Invoice.Custom3 (varchar 1000)

  // User/Audit
  fUser           String?   @map("f_user")                  // Invoice.fUser (varchar 50)

  // Collection Fields
  collMethod      Int?      @map("coll_method")             // Invoice.fieldcollmethod (smallint)
  collAmount      Decimal?  @db.Decimal(12, 2) @map("coll_amount") // Invoice.fieldcollamount
  collRef         String?   @map("coll_ref")                // Invoice.fieldcollref (varchar 100)

  // Email Tracking
  emailStatusCode Int       @default(0) @map("email_status_code") // Invoice.EMailStatus (int in SQL Server)
  sentBy          String?   @map("sent_by")                 // Invoice.SentBy (nvarchar 50)
  sentOn          DateTime? @map("sent_on")                 // Invoice.SentOn

  // TFM Integration
  tfmId           String?   @map("tfm_id")                  // Invoice.TFMID (varchar 100)
  tfmSource       String?   @map("tfm_source")              // Invoice.TFMSource (varchar 10)

  // Legacy display fields (for our app compatibility)
  date            DateTime                                  // Display date (maps to fDate)
  postingDate     DateTime  @map("posting_date")            // Posting date
  description     String?                                   // Display description (maps to fDesc)
  poNumber        String?   @map("po_number")               // Display PO (maps to po)
  statusDisplay   String    @default("Open") @map("status_display") // String status for UI

  // Labor Hours (app-specific, may map to JobI)
  reg             Decimal?  @db.Decimal(10, 2)
  ot              Decimal?  @db.Decimal(10, 2)
  ot17            Decimal?  @db.Decimal(10, 2)
  dt              Decimal?  @db.Decimal(10, 2)
  tt              Decimal?  @db.Decimal(10, 2)

  // Computed amounts for app display
  subTotal        Decimal   @default(0) @db.Decimal(12, 2) @map("sub_total")
  salesTax        Decimal   @default(0) @db.Decimal(12, 2) @map("sales_tax")
  nonTaxable      Decimal   @default(0) @db.Decimal(12, 2) @map("non_taxable")
  remainingUnpaid Decimal   @default(0) @db.Decimal(12, 2) @map("remaining_unpaid")

  // Timestamps (app tracking, not in legacy)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  premisesId      String?   @map("premises_id")             // Invoice.Loc → Loc.Loc
  premises        Premises? @relation(fields: [premisesId], references: [id])

  jobId           String?   @map("job_id")                  // Invoice.Job → Job.ID
  job             Job?      @relation(fields: [jobId], references: [id])

  // Line Items (InvoiceI table)
  items           InvoiceItem[]

  // Tickets linked to this invoice
  tickets         Ticket[]

  @@map("invoices")
  // SQL Server: @@map("Invoice")
}

// ============================================
// QUOTES (SQL Server: Quote table)
// ============================================
// Legacy: Quote.Ref is PK (int)
// Quote.Loc → Loc.Loc, Quote.Job → Job.ID, Quote.Invoice → Invoice.Ref

model Quote {
  id              String    @id @default(cuid())
  // SQL Server: Quote.Ref (int, PK)

  // From Quote table
  ref             Int?      @unique                         // Quote.Ref (int) - quote reference number
  fDate           DateTime? @map("f_date")                  // Quote.fDate - quote date
  fDesc           String?   @map("f_desc")                  // Quote.fDesc (text) - description
  fComments       String?   @map("f_comments")              // Quote.fComments (varchar max) - comments

  // Amounts
  amount          Decimal   @default(0) @db.Decimal(12, 4)  // Quote.Amount
  sTax            Decimal   @default(0) @db.Decimal(12, 4) @map("s_tax")  // Quote.STax - sales tax
  total           Decimal   @default(0) @db.Decimal(12, 4)  // Quote.Total
  taxable         Decimal   @default(0) @db.Decimal(12, 4)  // Quote.Taxable
  gTax            Decimal?  @db.Decimal(12, 4) @map("g_tax") // Quote.GTax - GST/other tax
  pstOnlyAmount   Decimal?  @db.Decimal(12, 2) @map("pst_only_amount") // Quote.PSTOnlyAmount

  // Tax Settings
  taxRegion       String?   @map("tax_region")              // Quote.TaxRegion (varchar 25)
