// Prisma Schema for ZEUS Field Service Management
// Clean snake_case database column names

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("User")
  avatar    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  createdJobs    Job[]        @relation("CreatedByUser")
  jobHistory     JobHistory[]
  activities     Activity[]
  files          File[]

  @@map("users")
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id            String   @id @default(cuid())
  name          String
  accountNumber String?  @unique @map("account_number")

  // Address fields
  address       String?
  city          String?
  state         String?
  zipCode       String?  @map("zip_code")
  country       String?  @default("United States")

  // Contact fields
  contact       String?
  phone         String?
  fax           String?
  cellular      String?
  email         String?
  website       String?

  // Classification
  type          String   @default("General")
  isActive      Boolean  @default(true) @map("is_active")
  billing       String?  @default("Individual")
  custom1       String?
  custom2       String?
  balance       Decimal  @default(0) @db.Decimal(12, 2)

  // Portal
  portalAccess  Boolean  @default(false) @map("portal_access")

  // Remarks
  remarks           String?
  salesRemarks      String?  @map("sales_remarks")
  currentYearSales  Decimal  @default(0) @db.Decimal(12, 2) @map("current_year_sales")
  priorYearSales    Decimal  @default(0) @db.Decimal(12, 2) @map("prior_year_sales")

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  premises      Premises[]
  jobs          Job[]
  contacts      Contact[]

  @@map("customers")
}

// ============================================
// CONTACTS (Customer Contacts)
// ============================================

model Contact {
  id          String   @id @default(cuid())
  name        String
  title       String?
  phone       String?
  fax         String?
  mobile      String?
  email       String?
  inv         Boolean  @default(false)
  es          Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

// ============================================
// PREMISES (Accounts/Buildings)
// ============================================

model Premises {
  id          String   @id @default(cuid())
  premisesId  String?  @unique @map("premises_id")
  name        String?
  address     String
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  country     String?  @default("United States")

  // Contact fields
  contact     String?
  phone       String?
  fax         String?
  cellular    String?
  email       String?
  website     String?

  // Classification
  type        String?  @default("Non-Contract")
  isActive    Boolean  @default(true) @map("is_active")
  balance     Decimal  @default(0) @db.Decimal(12, 2)

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id])
  jobs        Job[]
  units       Unit[]
  invoices    Invoice[]
  tickets     Ticket[]

  @@map("premises")
}

// ============================================
// UNITS (Elevator Units at a Premises)
// ============================================

model Unit {
  id           String   @id @default(cuid())
  unitNumber   String   @map("unit_number")
  unitType     String?  @map("unit_type")
  category     String?
  serial       String?
  manufacturer String?
  status       String?  @default("Active")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  premisesId   String   @map("premises_id")
  premises     Premises @relation(fields: [premisesId], references: [id])
  jobs         Job[]

  @@map("units")
}

// ============================================
// JOBS
// ============================================

model Job {
  id              String    @id @default(cuid())

  // Core Fields
  jobName         String    @map("job_name")
  externalId      String?   @unique @map("external_id")
  jobDescription  String?   @map("job_description")

  // Status & Type
  status          String    @default("Open")
  type            String?
  contractType    String?   @map("contract_type")
  customJobType   String?   @map("custom_job_type")
  customStatus    String?   @map("custom_status")
  priorityLevel   String?   @map("priority_level")

  // Dates
  date            DateTime?
  customDate      DateTime? @map("custom_date")
  dueDate         DateTime? @map("due_date")
  scheduleDate    DateTime? @map("schedule_date")
  compDate        DateTime? @map("comp_date")
  closeDate       DateTime? @map("close_date")

  // Hours
  reg             Decimal?  @db.Decimal(10, 2)
  ot              Decimal?  @db.Decimal(10, 2)
  ot17            Decimal?  @db.Decimal(10, 2)
  dt              Decimal?  @db.Decimal(10, 2)
  tt              Decimal?  @db.Decimal(10, 2)
  totalHours      Decimal?  @db.Decimal(10, 2) @map("total_hours")

  // Assignment
  supervisor      String?
  projectManager  String?   @map("project_manager")
  employeeFirstName String? @map("employee_first_name")

  // Billing
  billingTerms    String?   @map("billing_terms")
  chargeable      Boolean   @default(false)

  // Notes & Remarks
  sRemarks        String?   @map("s_remarks")
  customerRemarks String?   @map("customer_remarks")
  comments        String?

  // Other Fields
  template        String?
  level           String?
  source          String?
  office          String?
  reopen          Boolean   @default(false)
  tsCreatedBy     String?   @map("ts_created_by")
  repRequest      String?   @map("rep_request")
  bRev            String?   @map("b_rev")
  lastSyncTime    DateTime? @map("last_sync_time")

  // Custom Fields
  reqDate         DateTime? @map("req_date")
  folder          String?
  url             String?
  fineFault       String?   @map("fine_fault")
  wfMisu          String?   @map("wf_misu")
  mrRequest       String?   @map("mr_request")
  guzman          String?

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  customerId      String?   @map("customer_id")
  customer        Customer? @relation(fields: [customerId], references: [id])

  premisesId      String?   @map("premises_id")
  premises        Premises? @relation(fields: [premisesId], references: [id])

  unitId          String?   @map("unit_id")
  unit            Unit?     @relation(fields: [unitId], references: [id])

  createdById     String?   @map("created_by_id")
  createdBy       User?     @relation("CreatedByUser", fields: [createdById], references: [id])

  // Related records
  history         JobHistory[]
  activities      Activity[]
  files           File[]
  notes           Note[]
  tickets         Ticket[]
  invoices        Invoice[]

  @@map("jobs")
}

// ============================================
// JOB HISTORY (Audit Trail)
// ============================================

model JobHistory {
  id            String   @id @default(cuid())
  field         String
  originalValue String?  @map("original_value")
  newValue      String?  @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  jobId         String   @map("job_id")
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  userId        String?  @map("user_id")
  user          User?    @relation(fields: [userId], references: [id])

  @@map("job_history")
}

// ============================================
// ACTIVITY FEED
// ============================================

model Activity {
  id          String   @id @default(cuid())
  type        String
  content     String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  jobId       String?  @map("job_id")
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  @@map("activities")
}

// ============================================
// FILES
// ============================================

model File {
  id           String   @id @default(cuid())
  name         String
  url          String
  size         Int?
  mimeType     String?  @map("mime_type")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  jobId        String?  @map("job_id")
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  uploadedById String?  @map("uploaded_by_id")
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@map("files")
}

// ============================================
// NOTES
// ============================================

model Note {
  id          String   @id @default(cuid())
  title       String?
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  jobId       String?  @map("job_id")
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// ============================================
// TICKETS (Completed Time Tickets)
// ============================================

model Ticket {
  id              String   @id @default(cuid())
  ticketNumber    Int      @unique @map("ticket_number")
  workOrderNumber Int?     @map("work_order_number")

  // Date/Time
  date            DateTime
  completedDate   DateTime? @map("completed_date")

  // Classification
  type            String   @default("Other")  // Maintenance, Modernization, Repair, Other
  category        String?
  level           String?                     // e.g., "4-Violations"
  status          String   @default("Open")   // Open, Completed, Void

  // Location identifier (like 110WIL, 50HAV, etc.)
  accountId       String?  @map("account_id")

  // Personnel
  mechCrew        String?  @map("mech_crew")
  supervisor      String?
  wage            String?                     // e.g., "460 - A MECH MOD/REPAIR" (TODO: link to WageCodes table later)

  // Job & Unit (TODO: unitId relation to Unit model later)
  phase           Int?     @default(1)
  unitName        String?  @map("unit_name")  // e.g., "BARD P1" - currently text, will be relation later

  // Name & Address display (pulled from Premises, but can be overridden)
  nameAddress     String?  @map("name_address")

  // Scope of Work (textarea)
  scopeOfWork     String?  @map("scope_of_work")

  // Resolution (textarea)
  resolution      String?

  // Parts Used (textarea)
  partsUsed       String?  @map("parts_used")

  // Work Performed section
  workTime        String?  @map("work_time")  // Time like "03:42 PM"

  // Time Frame
  enRouteTime     String?  @map("en_route_time")
  onSiteTime      String?  @map("on_site_time")
  completedTime   String?  @map("completed_time")

  // Mileage
  mileageStarting Int?     @default(0) @map("mileage_starting")
  mileageEnding   Int?     @default(0) @map("mileage_ending")
  mileageTraveled Int?     @default(0) @map("mileage_traveled")

  // Time Spent (hours breakdown)
  hours           Decimal  @default(0) @db.Decimal(10, 2)  // This is "Regular" hours
  overtimeHours   Decimal  @default(0) @db.Decimal(10, 2) @map("overtime_hours")
  oneSevenHours   Decimal  @default(0) @db.Decimal(10, 2) @map("one_seven_hours")  // 1.7 Time
  doubleTimeHours Decimal  @default(0) @db.Decimal(10, 2) @map("double_time_hours")
  travelHours     Decimal  @default(0) @db.Decimal(10, 2) @map("travel_hours")
  totalHours      Decimal  @default(0) @db.Decimal(10, 2) @map("total_hours")
  estTime         Decimal  @default(0) @db.Decimal(10, 2) @map("est_time")
  difference      Decimal  @default(0) @db.Decimal(10, 2)

  // Expenses
  expensePhase    Int?     @default(1) @map("expense_phase")
  expenseMileage  Decimal  @default(0) @db.Decimal(10, 2) @map("expense_mileage")
  expenseZone     Decimal  @default(0) @db.Decimal(10, 2) @map("expense_zone")
  expenseTolls    Decimal  @default(0) @db.Decimal(10, 2) @map("expense_tolls")
  expenseMisc     Decimal  @default(0) @db.Decimal(10, 2) @map("expense_misc")
  expenseTotal    Decimal  @default(0) @db.Decimal(10, 2) @map("expense_total")

  // Checkbox statuses (from list view)
  bill            Boolean  @default(false)
  reviewed        Boolean  @default(false)
  pr              Boolean  @default(false)    // Payroll
  vd              Boolean  @default(false)    // Void
  inv             Boolean  @default(false)    // Invoiced

  // Checkbox statuses (from detail view)
  workCompleted   Boolean  @default(false) @map("work_completed")
  chargeable      Boolean  @default(false)
  emailOnSave     Boolean  @default(false) @map("email_on_save")
  updateLocation  Boolean  @default(false) @map("update_location")
  internetAccess  Boolean  @default(true) @map("internet_access")

  // Review Status
  reviewStatus    String?  @default("Dispatch Review") @map("review_status")

  // Contract Type (pulled from Premises/Job, but can store here)
  contractType    String?  @map("contract_type")

  // Internal Comments Only (textarea)
  internalComments String? @map("internal_comments")

  // Call tracking (shown in status bar)
  calledInBy      String?  @map("called_in_by")
  calledInDate    DateTime? @map("called_in_date")
  takenBy         String?  @map("taken_by")
  resolvedBy      String?  @map("resolved_by")

  // Email
  emailStatus     String?  @default("No Email Sent") @map("email_status")

  // Description/Notes (legacy field)
  description     String?

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  premisesId      String?  @map("premises_id")
  premises        Premises? @relation(fields: [premisesId], references: [id])

  jobId           String?  @map("job_id")
  job             Job?     @relation(fields: [jobId], references: [id])

  invoiceId       String?  @map("invoice_id")
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  // TODO: Add unitId relation when Unit module is built
  // unitId       String?  @map("unit_id")
  // unit         Unit?    @relation(fields: [unitId], references: [id])

  @@map("tickets")
}

// ============================================
// INVOICES
// ============================================

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   Int       @unique @map("invoice_number")

  // Dates
  postingDate     DateTime  @map("posting_date")
  date            DateTime

  // Classification
  type            String    @default("Other")  // Other, Maintenance, Modernization, Repair
  terms           String?   @default("Net 30 Days")
  priceLevel      String?   @map("price_level")

  // Reference Fields
  poNumber        String?   @map("po_number")
  mechSales       String?   @map("mech_sales")
  creditReq       String?   @map("credit_req")
  backup          String?

  // Status
  status          String    @default("Open")  // Open, Paid, Void
  emailSent       Boolean   @default(false) @map("email_sent")
  emailStatus     String?   @default("No Email Sent") @map("email_status")

  // Description
  description     String?
  jobRemarks      String?   @map("job_remarks")

  // Tax Fields
  taxRegion1      String?   @map("tax_region_1")
  taxRate1        Decimal   @default(0) @db.Decimal(8, 4) @map("tax_rate_1")
  taxRegion2      String?   @map("tax_region_2")
  taxRate2        Decimal   @default(0) @db.Decimal(8, 4) @map("tax_rate_2")
  taxFactor       Decimal   @default(100) @db.Decimal(8, 2) @map("tax_factor")

  // Labor Hours
  reg             Decimal?  @db.Decimal(10, 2)
  ot              Decimal?  @db.Decimal(10, 2)
  ot17            Decimal?  @db.Decimal(10, 2)
  dt              Decimal?  @db.Decimal(10, 2)
  tt              Decimal?  @db.Decimal(10, 2)

  // Amounts
  taxable         Decimal   @default(0) @db.Decimal(12, 2)
  nonTaxable      Decimal   @default(0) @db.Decimal(12, 2) @map("non_taxable")
  subTotal        Decimal   @default(0) @db.Decimal(12, 2) @map("sub_total")
  salesTax        Decimal   @default(0) @db.Decimal(12, 2) @map("sales_tax")
  total           Decimal   @default(0) @db.Decimal(12, 2)
  remainingUnpaid Decimal   @default(0) @db.Decimal(12, 2) @map("remaining_unpaid")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  premisesId      String?   @map("premises_id")
  premises        Premises? @relation(fields: [premisesId], references: [id])

  jobId           String?   @map("job_id")
  job             Job?      @relation(fields: [jobId], references: [id])

  // Line Items
  items           InvoiceItem[]

  // Tickets linked to this invoice
  tickets         Ticket[]

  @@map("invoices")
}

// ============================================
// INVOICE ITEMS (Line Items)
// ============================================

model InvoiceItem {
  id            String   @id @default(cuid())
  name          String
  quantity      Decimal  @default(1) @db.Decimal(10, 2)
  description   String?
  tax           Boolean  @default(false)
  price         Decimal  @default(0) @db.Decimal(12, 2)
  markupPercent Decimal  @default(0) @db.Decimal(5, 2) @map("markup_percent")
  amount        Decimal  @default(0) @db.Decimal(12, 2)
  measure       String?  @default("Each")
  phase         Int?     @default(0)

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  invoiceId     String   @map("invoice_id")
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}
