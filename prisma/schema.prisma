  accountId       Int?      @map("account_id")             // CreditCardTrans.idAccount
  amount          Decimal?  @db.Decimal(19, 4)             // CreditCardTrans.Amount (money)
  bankAccountId   Int?      @map("bank_account_id")        // CreditCardTrans.idBankAccount
  depositId       Int?      @map("deposit_id")             // CreditCardTrans.idDep
  dateCreated     DateTime  @map("date_created")           // CreditCardTrans.DateCreated
  dateSubmitted   DateTime? @map("date_submitted")         // CreditCardTrans.DateSubmitted
  dateApproved    DateTime? @map("date_approved")          // CreditCardTrans.DateApproved
  dateDeposited   DateTime? @map("date_deposited")         // CreditCardTrans.DateDeposited
  dateApplied     DateTime? @map("date_applied")           // CreditCardTrans.DateApplied
  receiptData     String?   @map("receipt_data")           // CreditCardTrans.ReceiptData (text)
  userName        String?   @map("user_name")              // CreditCardTrans.UserName (varchar 50)
  branchId        Int?      @map("branch_id")              // CreditCardTrans.idBranch

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  creditCardId    String?   @map("credit_card_id")
  creditCard      CreditCard? @relation(fields: [creditCardId], references: [id])

  @@map("credit_card_transactions")
  // SQL Server: @@map("CreditCardTrans")
}

// ============================================
// CASH RECEIPTS (Deposits)
// ============================================

model CashReceipt {
  id            String   @id @default(cuid())
  refNumber     Int      @unique @map("ref_number")
  date          DateTime
  description   String?
  amount        Decimal  @default(0) @db.Decimal(12, 2)
  fsCatalogue   String?  @map("fs_catalogue")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  bankAccountId String      @map("bank_account_id")
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("cash_receipts")
}

// ============================================
// INVOICE ITEMS (Line Items)
// ============================================

model InvoiceItem {
  id            String   @id @default(cuid())
  // SQL Server: InvoiceI.ID (int, PK)

  // From InvoiceI table
  legacyId      Int?     @unique @map("legacy_id")         // InvoiceI.ID (int)
  line          Int?                                        // InvoiceI.Line (smallint) - line number
  acct          Int?                                        // InvoiceI.Acct (int) - GL account
  quan          Decimal  @default(1) @db.Decimal(10, 2)     // InvoiceI.Quan
  fDesc         String?  @map("f_desc")                     // InvoiceI.fDesc (varchar 8000)
  price         Decimal  @default(0) @db.Decimal(12, 4)     // InvoiceI.Price
  amount        Decimal  @default(0) @db.Decimal(12, 2)     // InvoiceI.Amount
  sTax          Int?     @default(0) @map("s_tax")          // InvoiceI.STax (smallint) - taxable flag
  measure       String?  @default("Each")                   // InvoiceI.Measure (varchar 15)
  disc          Decimal? @db.Decimal(10, 4)                 // InvoiceI.Disc - discount
  pstTax        Int?     @default(0) @map("pst_tax")        // InvoiceI.PSTTax (smallint)
  savingsAmount Decimal? @db.Decimal(12, 2) @map("savings_amount") // InvoiceI.savingsAmount
  originalPrice Decimal? @db.Decimal(12, 4) @map("original_price") // InvoiceI.OriginalPrice
  flatRateId    Int?     @map("flat_rate_id")               // InvoiceI.FlatRateID
  usa           Boolean  @default(false)                    // InvoiceI.USA (bit)
  coupon        Boolean  @default(false)                    // InvoiceI.Coupon (bit)

  // Transaction references
  transId       Int?     @map("trans_id")                   // InvoiceI.TransID
  jobItemId     Int?     @map("job_item_id")                // InvoiceI.JobItem → JobI.ID

  // TFM Integration
  tfmId         String?  @map("tfm_id")                     // InvoiceI.TFMID (varchar 100)
  tfmSource     String?  @map("tfm_source")                 // InvoiceI.TFMSource (varchar 10)

  // App display fields (for compatibility)
  name          String                                      // Display name
  description   String?                                     // Display description (maps to fDesc)
  quantity      Decimal  @default(1) @db.Decimal(10, 2)     // Display quantity (maps to quan)
  tax           Boolean  @default(false)                    // Display tax flag
  markupPercent Decimal  @default(0) @db.Decimal(5, 2) @map("markup_percent")
  phase         Int?     @default(0)

  // Timestamps (app tracking)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  invoiceId     String   @map("invoice_id")                 // InvoiceI.Ref → Invoice.Ref
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  jobId         String?  @map("job_id")                     // InvoiceI.Job → Job.ID
  job           Job?     @relation(fields: [jobId], references: [id])

  @@map("invoice_items")
  // SQL Server: @@map("InvoiceI")
}

// ============================================
// CHART OF ACCOUNTS (SQL Server: Chart table)
// ============================================
// General Ledger accounts

model ChartAccount {
  id            String   @id @default(cuid())
  // SQL Server: Chart.ID (int, PK)

  legacyId      Int?     @unique @map("legacy_id")         // Chart.ID
  acct          Int?     @map("acct")                      // Chart.Acct (int) - account number
  fDesc         String?  @map("f_desc")                    // Chart.fDesc (varchar 75) - description
  type          Int?                                       // Chart.Type (smallint) - account type
  cat           Int?                                       // Chart.Cat (smallint) - category
  bal           Int?                                       // Chart.Bal (smallint) - normal balance
  status        Int?     @default(1)                       // Chart.Status (smallint)
  budget        Decimal? @db.Decimal(12, 2)                // Chart.Budget
  budgetM       Decimal? @db.Decimal(12, 2) @map("budget_m") // Chart.BudgetM
  bank          Int?                                       // Chart.Bank (smallint) - is bank account
  bankType      Int?     @map("bank_type")                 // Chart.BankType
  reportO       Int?     @map("report_o")                  // Chart.ReportO (smallint)
  inUse         Int      @default(1) @map("in_use")        // Chart.InUse (smallint)
  fsGroup       Int?     @map("fs_group")                  // Chart.fsGroup
  fsCatalogue   String?  @map("fs_catalogue")              // Chart.fsCatalogue (varchar 50)
  custom1       String?                                    // Chart.Custom1 (varchar 50)
  custom2       String?                                    // Chart.Custom2 (varchar 50)

  // App display fields
  name          String?                                    // Display name (from fDesc)
  accountNumber String?  @map("account_number")            // Display account number (from acct)
  isActive      Boolean  @default(true) @map("is_active")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  balances      ChartAccountBalance[]
  transactions  Transaction[]

  @@map("chart_accounts")
  // SQL Server: @@map("Chart")
}

// ============================================
// CHART ACCOUNT BALANCES (SQL Server: ChartA table)
// ============================================
// GL account balances by period

model ChartAccountBalance {
  id            String   @id @default(cuid())

  chartId       Int?     @map("chart_id")                  // ChartA.Chart → Chart.ID
  period        Int?                                       // ChartA.Period (smallint) - accounting period
  fYear         Int?     @map("f_year")                    // ChartA.fYear (smallint) - fiscal year
  db            Decimal  @default(0) @db.Decimal(12, 2)    // ChartA.DB - debit
  cr            Decimal  @default(0) @db.Decimal(12, 2)    // ChartA.CR - credit
  balance       Decimal  @default(0) @db.Decimal(12, 2)    // ChartA.Balance
  transNum      Int?     @map("trans_num")                 // ChartA.TransN - transaction count

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  chartAccountId String? @map("chart_account_id")
  chartAccount   ChartAccount? @relation(fields: [chartAccountId], references: [id])

  @@map("chart_account_balances")
  // SQL Server: @@map("ChartA")
}

// ============================================
// TRANSACTIONS (SQL Server: Trans table)
// ============================================
// General ledger journal entries

model Transaction {
  id            String   @id @default(cuid())
  // SQL Server: Trans.ID (int, PK)

  legacyId      Int?     @unique @map("legacy_id")         // Trans.ID
  ref           Int?                                       // Trans.Ref (int) - reference number
  fDate         DateTime? @map("f_date")                   // Trans.fDate - transaction date
  fDesc         String?  @map("f_desc")                    // Trans.fDesc (varchar 255)
  type          Int?                                       // Trans.Type (smallint)
  source        String?                                    // Trans.Source (varchar 15) - origin module
  period        Int?                                       // Trans.Period (smallint)
  fYear         Int?     @map("f_year")                    // Trans.fYear (smallint)
  status        Int?     @default(0)                       // Trans.Status (smallint)
  batch         Int?                                       // Trans.Batch
  db            Decimal  @default(0) @db.Decimal(12, 2)    // Trans.DB - total debit
  cr            Decimal  @default(0) @db.Decimal(12, 2)    // Trans.CR - total credit
  fUser         String?  @map("f_user")                    // Trans.fUser (varchar 50)

  // Optional references
  locId         Int?     @map("loc_id")                    // Trans.Loc → Loc.Loc
  jobId         Int?     @map("job_legacy_id")             // Trans.Job → Job.ID
  vendorId      Int?     @map("vendor_legacy_id")          // Trans.Vendor → Vendor.ID

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  chartAccountId String? @map("chart_account_id")
  chartAccount   ChartAccount? @relation(fields: [chartAccountId], references: [id])

  items         TransactionItem[]

  @@map("transactions")
  // SQL Server: @@map("Trans")
}

// ============================================
// TRANSACTION ITEMS (SQL Server: TransI table)
// ============================================
// Journal entry line items

model TransactionItem {
  id            String   @id @default(cuid())

  line          Int?                                       // TransI.Line (smallint) - line number
  acct          Int?                                       // TransI.Acct (int) - GL account
  fDesc         String?  @map("f_desc")                    // TransI.fDesc (varchar 255)
  db            Decimal  @default(0) @db.Decimal(12, 2)    // TransI.DB - debit amount
  cr            Decimal  @default(0) @db.Decimal(12, 2)    // TransI.CR - credit amount
  locId         Int?     @map("loc_id")                    // TransI.Loc → Loc.Loc
  jobId         Int?     @map("job_legacy_id")             // TransI.Job → Job.ID

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  transactionId String   @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_items")
  // SQL Server: @@map("TransI")
}

// ============================================
// RECURRING GL ADJUSTMENTS (SQL Server: GLARecur)
// ============================================
// Recurring journal entry templates

model GLARecurring {
  id            String   @id @default(cuid())
  // SQL Server: GLARecur.ID (int, PK)

  legacyId      Int?     @unique @map("legacy_id")         // GLARecur.ID
  fDesc         String?  @map("f_desc")                    // GLARecur.fDesc (varchar 255)
  status        Int?     @default(1)                       // GLARecur.Status (smallint)
  frequency     Int?                                       // GLARecur.Frequency (smallint)
  dDate         DateTime? @map("d_date")                   // GLARecur.DDate - next due date
  amount        Decimal? @db.Decimal(12, 2)                // GLARecur.Amount

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  items         GLARecurringItem[]

  @@map("gla_recurring")
  // SQL Server: @@map("GLARecur")
}

// ============================================
// RECURRING GL ADJUSTMENT ITEMS (SQL Server: GLARecurI)
// ============================================

model GLARecurringItem {
  id            String   @id @default(cuid())

  line          Int?                                       // GLARecurI.Line (smallint)
  acct          Int?                                       // GLARecurI.Acct (int) - GL account
  fDesc         String?  @map("f_desc")                    // GLARecurI.fDesc (varchar 255)
  db            Decimal  @default(0) @db.Decimal(12, 2)    // GLARecurI.DB - debit
  cr            Decimal  @default(0) @db.Decimal(12, 2)    // GLARecurI.CR - credit
  locId         Int?     @map("loc_id")                    // GLARecurI.Loc → Loc.Loc
  jobId         Int?     @map("job_legacy_id")             // GLARecurI.Job → Job.ID

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  glaRecurringId String  @map("gla_recurring_id")
  glaRecurring   GLARecurring @relation(fields: [glaRecurringId], references: [id], onDelete: Cascade)

  @@map("gla_recurring_items")
  // SQL Server: @@map("GLARecurI")
}

// ============================================
// PAGE FIELD CONFIGURATION (Admin Customization)
// ============================================
// Stores per-page field display settings for metadata-driven UI
// Allows admins to rename field labels, reorder fields, hide fields
// without changing backend data connections

model PageFieldConfig {
  id            String   @id @default(cuid())

  pageId        String   @map("page_id")              // Module/page identifier (e.g., "dispatch", "customers", "invoices")
  fieldName     String   @map("field_name")           // Original backend field name (data key)
  displayLabel  String   @map("display_label")        // Custom label shown in UI
  sortOrder     Int      @default(0) @map("sort_order")  // Display order (lower = first)
  visible       Boolean  @default(true)               // Whether to show this field
  width         Int?                                  // Optional column width in pixels
  section       String?                               // Optional section grouping
  format        String?                               // Optional display format (e.g., "currency", "date", "phone")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Unique constraint: one config per field per page
  @@unique([pageId, fieldName])
  @@map("page_field_configs")
}

// ============================================
// PAGE SECTION CONFIG (Admin Customization)
// ============================================
// Stores section-level configuration for pages

model PageSectionConfig {
  id            String   @id @default(cuid())

  pageId        String   @map("page_id")              // Module/page identifier
  sectionName   String   @map("section_name")         // Section identifier
  displayLabel  String   @map("display_label")        // Section header text
  sortOrder     Int      @default(0) @map("sort_order")
  collapsed     Boolean  @default(false)              // Default collapsed state
  visible       Boolean  @default(true)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([pageId, sectionName])
  @@map("page_section_configs")
}

// ============================================
// PICKLIST VALUES (Dynamic Dropdown Options)
// ============================================
// Stores all select/dropdown options per module per field.
// Replaces hardcoded arrays throughout the app.
// Use pageId="_global" for shared picklists (US States, countries, etc.)

model PicklistValue {
  id          String   @id @default(cuid())

  pageId      String   @map("page_id")
  fieldName   String   @map("field_name")
  value       String
  label       String
  sortOrder   Int      @default(0) @map("sort_order")
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  color       String?
  icon        String?
  metadata    Json?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([pageId, fieldName, value])
  @@index([pageId, fieldName])
  @@map("picklist_values")
}

// ============================================
// STATUS WORKFLOW (Configurable Status Transitions)
// ============================================
// Defines valid status transitions per module.
// fromStatus="_initial" means this status is available when creating a new record.

model StatusWorkflow {
  id            String   @id @default(cuid())

  pageId        String   @map("page_id")
  fromStatus    String   @map("from_status")
  toStatus      String   @map("to_status")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  requiresRole  String?  @map("requires_role")
  requiresNote  Boolean  @default(false) @map("requires_note")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([pageId, fromStatus, toStatus])
  @@index([pageId, fromStatus])
  @@map("status_workflows")
}

// ============================================
// EMAIL NOTIFICATIONS
// ============================================

model EmailTrigger {
  id          String   @id @default(cuid())

  event       String   // e.g., "ticket.created", "ticket.statusChanged", "ticket.completed"
  label       String   // Human-readable name, e.g., "New Ticket Created"
  description String?  // Optional description of what this trigger does
  isActive    Boolean  @default(true) @map("is_active")
  recipients  String   // Comma-separated emails or special tokens like "{assignee}", "{dispatcher}"
  subject     String   // Email subject template (supports {{variables}})
  bodyHtml    String   @map("body_html") @db.Text // Email body HTML template

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  logs        EmailLog[]

  @@unique([event])
  @@map("email_triggers")
}

model EmailLog {
  id          String   @id @default(cuid())

  triggerId   String?  @map("trigger_id")
  trigger     EmailTrigger? @relation(fields: [triggerId], references: [id], onDelete: SetNull)
  event       String   // The event that fired
  recipients  String   // Who it was sent to
  subject     String
  status      String   @default("sent") // "sent", "failed"
  error       String?  // Error message if failed

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([triggerId])
  @@index([createdAt])
  @@map("email_logs")
}

model EmailSettings {
  id            String   @id @default("singleton") // Only one row ever
  smtpHost      String   @default("") @map("smtp_host")
  smtpPort      Int      @default(587) @map("smtp_port")
  smtpUser      String   @default("") @map("smtp_user")
  smtpPassword  String   @default("") @map("smtp_password") // Stored encrypted in production
  smtpFrom      String   @default("") @map("smtp_from")
  isConfigured  Boolean  @default(false) @map("is_configured")

  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("email_settings")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   // Template name, e.g. "Welcome New Customer"
  subject     String   // Subject line template (supports {{variables}})
  bodyHtml    String   @map("body_html") @db.Text // Email body HTML
  category    String   @default("general") // "notification", "sequence", "general"
  isActive    Boolean  @default(true) @map("is_active")

  createdBy   String?  @map("created_by") // User who created it

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sequenceSteps SequenceStep[] // Steps that reference this template

  @@map("email_templates")
}

// ─── Email Sequences ──────────────────────────────────────────────

model Sequence {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  status        String   @default("draft") // draft, active, paused, archived
  type          String?  // sales, service, ar, onboarding
  exitOnReply   Boolean  @default(true) @map("exit_on_reply")
  exitOnBounce  Boolean  @default(true) @map("exit_on_bounce")

  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  steps         SequenceStep[]
  enrollments   SequenceEnrollment[]

  @@map("sequences")
}

model SequenceStep {
  id          String   @id @default(cuid())
  sequenceId  String   @map("sequence_id")
  stepOrder   Int      @map("step_order")
  delayDays   Int      @default(0) @map("delay_days")
  subject     String   @default("")
  bodyHtml    String   @default("") @map("body_html") @db.Text
  templateId  String?  @map("template_id")
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sequence    Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template    EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  executions  SequenceStepExecution[]

  @@map("sequence_steps")
}

model SequenceEnrollment {
  id              String    @id @default(cuid())
  sequenceId      String    @map("sequence_id")
  contactEmail    String    @map("contact_email")
  contactName     String?   @map("contact_name")
  premisesId      String?   @map("premises_id")
  status          String    @default("active") // active, paused, completed, bounced, replied, failed
  currentStep     Int       @default(1) @map("current_step")

  enrolledAt      DateTime  @default(now()) @map("enrolled_at")
  enrolledBy      String?   @map("enrolled_by")
  completedAt     DateTime? @map("completed_at")
  exitReason      String?   @map("exit_reason")

  sequence        Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  executions      SequenceStepExecution[]

  @@unique([sequenceId, contactEmail])
  @@map("sequence_enrollments")
}

model SequenceStepExecution {
  id            String    @id @default(cuid())
  enrollmentId  String    @map("enrollment_id")
  stepId        String    @map("step_id")
  status        String    @default("scheduled") // scheduled, sent, failed, skipped
  scheduledAt   DateTime  @map("scheduled_at")
  sentAt        DateTime? @map("sent_at")
  errorMessage  String?   @map("error_message") @db.Text

  createdAt     DateTime  @default(now()) @map("created_at")

  enrollment    SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step          SequenceStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("sequence_step_executions")
}
