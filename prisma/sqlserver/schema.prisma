// Prisma Schema for SQL Server (Total Service) - READ ONLY
// Run: npx prisma db pull --schema=prisma/sqlserver/schema.prisma
// This will auto-discover ALL tables and fields from SQL Server

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client-sqlserver"
}

datasource db {
  provider = "sqlserver"
  url      = env("SQLSERVER_URL")
}

// Tables will be auto-generated by running:
// npx prisma db pull --schema=prisma/sqlserver/schema.prisma
